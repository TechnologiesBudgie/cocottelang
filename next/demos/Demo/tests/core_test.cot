# tests/core_test.cot — Core language tests
# Run with: cocotte test

library add "utils.cotlib"

print "Running core tests..."

# ── Arithmetic ────────────────────────────────────────────────────────────────
assert_eq(2 + 3, 5)
assert_eq(10 - 4, 6)
assert_eq(3 * 7, 21)
assert_eq(10 % 3, 1)
assert_eq(abs(-5), 5)
assert_eq(max(3, 7), 7)
assert_eq(min(3, 7), 3)
assert_eq(clamp(150, 0, 100), 100)
assert_eq(clamp(-10, 0, 100), 0)
assert_eq(clamp(50, 0, 100), 50)
assert_eq(sign(-5), -1)
assert_eq(sign(0), 0)
assert_eq(sign(5), 1)
assert_eq(pow(2, 10), 1024)
assert_eq(sqrt(25), 5)
assert_eq(floor(3.9), 3)
assert_eq(ceil(3.1), 4)
assert_eq(round(3.5), 4)

# ── String methods ────────────────────────────────────────────────────────────
assert_eq("hello".upper(), "HELLO")
assert_eq("HELLO".lower(), "hello")
assert_eq("  hi  ".trim(), "hi")
assert_eq("hello".len(), 5)
assert_eq("hello".get(1), "e")
assert_eq("hello".slice(1, 4), "ell")
assert_eq("hello".index_of("ll"), 2)
assert_eq("hello".index_of("xyz"), -1)
assert_eq("ha".repeat(3), "hahaha")
assert_eq("7".pad_left(4, "0"), "0007")
assert_eq("hi".pad_right(5, "."), "hi...")
assert_eq("hello".contains("ell"), true)
assert_eq("hello".contains("xyz"), false)
assert_eq("hello".starts_with("hel"), true)
assert_eq("hello".ends_with("llo"), true)
assert_eq("hello".replace("l", "r"), "herro")
assert_eq("hello world".split(" ").len(), 2)
assert_eq("a\nb\nc".split_lines().len(), 3)
assert_eq("hello".is_empty(), false)
assert_eq("".is_empty(), true)

# ── Type checks ───────────────────────────────────────────────────────────────
assert_eq(is_number(42), true)
assert_eq(is_number("42"), false)
assert_eq(is_string("hi"), true)
assert_eq(is_string(42), false)
assert_eq(is_list([]), true)
assert_eq(is_list({}), false)
assert_eq(is_map({}), true)
assert_eq(is_bool(true), true)
assert_eq(is_nil(nil), true)
assert_eq(is_nil(0), false)

# ── Number formatting ─────────────────────────────────────────────────────────
assert_eq(format_number(3.14159, 2), "3.14")
assert_eq(format_number(3.14159, 0), "3")
assert_eq(to_number("42"), 42)
assert_eq(to_string(42), "42")
assert_eq(number_to_int(3.9), 3)
assert_eq(char_code("A"), 65)
assert_eq(code_char(65), "A")

# ── List methods ──────────────────────────────────────────────────────────────
var lst = [3, 1, 4, 1, 5, 9, 2, 6]
assert_eq(lst.len(), 8)
assert_eq(lst.get(0), 3)
assert_eq(lst.first(), 3)
assert_eq(lst.last(), 6)
assert_eq(lst.contains(5), true)
assert_eq(lst.contains(7), false)
assert_eq(lst.index_of(4), 2)
assert_eq(lst.index_of(99), -1)
assert_eq(lst.slice(1, 4).join(","), "1,4,1")

var copy = lst.copy()
copy.sort()
assert_eq(copy.join(","), "1,1,2,3,4,5,6,9")
assert_eq(lst.get(0), 3)   # original unchanged

var doubled = [1,2,3].map(func(x) return x * 2 end)
assert_eq(doubled.join(","), "2,4,6")

var evens = [1,2,3,4,5].filter(func(x) return x % 2 == 0 end)
assert_eq(evens.join(","), "2,4")

var total = [1,2,3,4,5].reduce(func(a,x) return a + x end, 0)
assert_eq(total, 15)

var first_big = [1,2,3,8,9].find(func(x) return x > 5 end)
assert_eq(first_big, 8)

var cnt = [1,2,3,4,5].count(func(x) return x > 3 end)
assert_eq(cnt, 2)

# ── Map methods ───────────────────────────────────────────────────────────────
var m = {"a": 1, "b": 2, "c": 3}
assert_eq(m.get("a"), 1)
assert_eq(m.has_key("b"), true)
assert_eq(m.has_key("z"), false)
assert_eq(m.len(), 3)
m.set("d", 4)
assert_eq(m.len(), 4)

# ── Control flow ──────────────────────────────────────────────────────────────
var acc = 0
for i in range(1, 6)
    acc = acc + i
end
assert_eq(acc, 15)

var n = 0
while n < 5
    n = n + 1
end
assert_eq(n, 5)

var broke_at = 0
for i in range(1, 100)
    if i > 5
        break
    end
    broke_at = i
end
assert_eq(broke_at, 5)

# ── Functions & closures ──────────────────────────────────────────────────────
func sum2(a, b) return a + b end
assert_eq(sum2(3, 4), 7)

func factorial(n)
    if n <= 1
        return 1
    end
    return n * factorial(n - 1)
end
assert_eq(factorial(5), 120)
assert_eq(factorial(10), 3628800)

func make_adder(n)
    return func(x) return x + n end
end
var add5 = make_adder(5)
assert_eq(add5(3), 8)
assert_eq(add5(10), 15)

# ── Error handling ────────────────────────────────────────────────────────────
var caught = false
try
    divide 1 by 0
catch err
    caught = true
end
assert_eq(caught, true)

var err_msg = ""
try
    to_number("not a number")
catch e
    err_msg = e
end
assert(err_msg != "", "should have caught error")

# ── Library (utils.cotlib) ────────────────────────────────────────────────────
assert_eq(utils.is_prime(2), true)
assert_eq(utils.is_prime(17), true)
assert_eq(utils.is_prime(18), false)
assert_eq(utils.is_prime(1), false)
assert_eq(utils.gcd(48, 18), 6)
assert_eq(utils.gcd(100, 25), 25)
assert_eq(utils.primes_up_to(10).join(","), "2,3,5,7")
assert_eq(utils.caesar("hello", 3), "khoor")
assert_eq(utils.reverse_string("hello"), "olleh")
assert_eq(utils.is_palindrome("racecar"), true)
assert_eq(utils.is_palindrome("hello"), false)
assert_eq(utils.count_vowels("hello"), 2)
assert_eq(utils.word_count("hello world foo"), 3)
assert_eq(utils.title_case("hello world"), "Hello World")
assert_eq(utils.sum_list([1,2,3,4,5]), 15)
assert_eq(utils.unique([1,2,2,3,3,3]).len(), 3)

print "All " + 100 + "+ tests passed!"
