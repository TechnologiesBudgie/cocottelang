[project]
name = "CocotteDemo"
author = "You"

[variables]
BINARY = "dist/CocotteDemo"

[tasks.run]
cocotte run src/main.cot

[tasks.run-gui]
cocotte run src/gui_demo.cot

[tasks.run-files]
cocotte run src/files_demo.cot

[tasks.run-classes]
cocotte run src/classes_demo.cot

[tasks.run-functional]
cocotte run src/functional_demo.cot

[tasks.run-all]
cocotte run src/main.cot
cocotte run src/classes_demo.cot
cocotte run src/functional_demo.cot
cocotte run src/files_demo.cot

[tasks.build]
cocotte build src/main.cot --release

[tasks.test]
cocotte test

[tasks.clean]
cocotte clean
