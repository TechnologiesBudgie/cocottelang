# stdlib_test.cot — Core language and stdlib tests
# Run with: cocotte test

# ── Arithmetic ────────────────────────────────────────────────────────────────
assert_eq(2 + 3, 5)
assert_eq(10 - 4, 6)
assert_eq(3 * 7, 21)
assert_eq(divide 10 by 4, 2.5)
assert_eq(10 % 3, 1)
assert_eq(abs(-5), 5)
assert_eq(sqrt(9), 3)
assert_eq(pow(2, 8), 256)
assert_eq(floor(3.9), 3)
assert_eq(ceil(3.1), 4)
assert_eq(round(3.5), 4)
assert_eq(max(1, 9), 9)
assert_eq(min(1, 9), 1)

# ── Strings ───────────────────────────────────────────────────────────────────
assert_eq("hello".upper(), "HELLO")
assert_eq("WORLD".lower(), "world")
assert_eq("  hi  ".trim(), "hi")
assert_eq("hello".len(), 5)
assert_eq("hello".contains("ell"), true)
assert_eq("hello".starts_with("hel"), true)
assert_eq("hello".ends_with("llo"), true)
assert_eq("hello".replace("l", "r"), "herro")
assert_eq("a,b,c".split(",").len(), 3)
assert_eq("ab".repeat(3), "ababab")
assert_eq(to_string(42), "42")
assert_eq(to_number("3.14"), 3.14)

# ── Lists ─────────────────────────────────────────────────────────────────────
var lst = [1, 2, 3, 4, 5]
assert_eq(lst.len(), 5)
assert_eq(lst.first(), 1)
assert_eq(lst.last(), 5)
assert_eq(lst.get(2), 3)
assert_eq(lst.contains(3), true)
assert_eq(lst.contains(99), false)
assert_eq(lst.map(func(x) return x * 2 end).len(), 5)
assert_eq(lst.filter(func(x) return x > 3 end).len(), 2)
assert_eq(lst.reduce(func(a, b) return a + b end, 0), 15)
assert_eq(lst.join(", "), "1, 2, 3, 4, 5")

var lst2 = [3, 1, 4, 1, 5]
lst2.sort()
assert_eq(lst2.first(), 1)
assert_eq(lst2.last(), 5)

# ── Maps ──────────────────────────────────────────────────────────────────────
var m = {"name": "Alice", "age": 30}
assert_eq(m.get("name"), "Alice")
assert_eq(m.has_key("age"), true)
assert_eq(m.has_key("email"), false)
m.set("email", "alice@example.com")
assert_eq(m.has_key("email"), true)
assert_eq(m.len(), 3)

# ── Control flow ──────────────────────────────────────────────────────────────
var result = 0
for i in range(0, 5)
    result = result + i
end
assert_eq(result, 10)

var count = 0
var j = 0
while j < 5
    count = count + 1
    j = j + 1
end
assert_eq(count, 5)

# ── Functions & closures ──────────────────────────────────────────────────────
func add(a, b)
    return a + b
end
assert_eq(add(3, 4), 7)

func make_adder(n)
    return func(x) return x + n end
end
var add5 = make_adder(5)
assert_eq(add5(10), 15)

# ── Classes ───────────────────────────────────────────────────────────────────
class Counter
    func init(start)
        self.n = start
    end
    func inc()
        self.n = self.n + 1
    end
    func val()
        return self.n
    end
end
var c = Counter(10)
c.inc()
c.inc()
assert_eq(c.val(), 12)

# ── Type checks ───────────────────────────────────────────────────────────────
assert_eq(type_of(42), "number")
assert_eq(type_of("hi"), "string")
assert_eq(type_of(true), "bool")
assert_eq(type_of([]), "list")
assert_eq(type_of({}), "map")
assert_eq(type_of(nil), "nil")
assert_eq(is_number(42), true)
assert_eq(is_string("x"), true)
assert_eq(is_list([1,2]), true)

# ── Error handling ────────────────────────────────────────────────────────────
var caught = false
try
    var bad = read_file("__nonexistent_file_xyz__.txt")
catch err
    caught = true
end
assert_eq(caught, true)

# ── Stdlib modules ────────────────────────────────────────────────────────────
module add "math"
assert_eq(math.floor(3.9), 3)
assert_eq(math.abs(-7), 7)
assert(math.PI > 3.14, "PI should be > 3.14")

module add "json"
var obj = json.parse('{"x": 1, "y": 2}')
assert_eq(obj.get("x"), 1)
assert_eq(json.stringify({"a": 1}), '{"a":1}')

module add "fmt"
assert_eq(fmt.pad_left("5", 3, "0"), "005")

print "All tests passed!"
