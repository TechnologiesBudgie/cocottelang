library add "src/stdlib/systeminfo.cotlib"
var plat = systeminfo.platform()
check("systeminfo platform", plat == "linux" or plat == "macos" or plat == "windows", true)
check("systeminfo cpu_count > 0", systeminfo.cpu_count() > 0, true)
var info_map = systeminfo.info()
check("systeminfo info has hostname", info_map.has_key("hostname"), true)
check("systeminfo info has platform", info_map.has_key("platform"), true)

# ── process ────────────────────────────────────────────────────────────────────
section("process")
library add "src/stdlib/process.cotlib"
var echo_result = process.run("echo hello")
check("process run", echo_result.trim(), "hello")
var lines = process.run_lines("echo -e 'a\nb\nc'")
check("process run_lines", lines.len() >= 3, true)
check("process which", process.which("echo") != nil, true)
check("process command_exists true", process.command_exists("echo"), true)
check("process command_exists false", process.command_exists("totally_fake_cmd_xyz"), false)

# ── git ────────────────────────────────────────────────────────────────────────
section("git")
library add "src/stdlib/git.cotlib"
# Only test non-destructive functions
var is_repo = git.is_repo()
check("git is_repo returns bool", is_repo == true or is_repo == false, true)
if is_repo
    var branch = git.current_branch()
    check("git branch non-empty", branch.len() >= 0, true)
end

# ── config ─────────────────────────────────────────────────────────────────────
section("config")
library add "src/stdlib/config.cotlib"
var cfg_path = "/tmp/cocotte_cfg_test.json"
var cfg = config.load(cfg_path, {"port": 8080, "debug": false, "name": "test"})
check("config get default port", cfg.get("port", 0), 8080)
check("config get default debug", cfg.get("debug", true), false)
cfg.set("port", 9000)
check("config set", cfg.get("port", 0), 9000)
cfg.save()
var cfg2 = config.load(cfg_path, {"port": 0})
check("config save/load", cfg2.get("port", 0), 9000)
delete_file(cfg_path)

# ── events ─────────────────────────────────────────────────────────────────────
section("events")
library add "src/stdlib/events.cotlib"
var emitter = events.create()
var received = []
emitter.on("data", func(d) received.push(d) end)
emitter.on("data", func(d) received.push(d + "2") end)
emitter.emit("data", "hello")
check("events on count", received.len(), 2)
check("events on value", received.get(0), "hello")
check("events listener count", emitter.count("data"), 2)
var once_count = 0
emitter.once("tick", func(_d) once_count = once_count + 1 end)
emitter.emit("tick", nil)
emitter.emit("tick", nil)
check("events once fires once", once_count, 1)
emitter.clear()
check("events clear", emitter.count("data"), 0)

# ── state ──────────────────────────────────────────────────────────────────────
section("state")
library add "src/stdlib/state.cotlib"
var store = state.create({"count": 0})
var state_log = []
store.subscribe(func(s) state_log.push(s.get("count")) end)
store.update("count", 1)
store.update("count", 2)
check("state subscribe", state_log.len(), 2)
check("state value", store.get_state().get("count"), 2)
store.undo()
check("state undo", store.get_state().get("count"), 1)
check("state history", store.history_len(), 3)

# ── cache roundtrip ────────────────────────────────────────────────────────────
# (already tested above)

# ── pipeline ───────────────────────────────────────────────────────────────────
section("pipeline")
library add "src/stdlib/pipeline.cotlib"
var p = pipeline.create()
    .pipe(func(x) return x * 2 end)
    .pipe(func(x) return x + 10 end)
    .pipe(func(x) return to_string(x) end)
check("pipeline run", p.run(5), "20")
var results = p.run_all([1, 2, 3])
check("pipeline run_all len", results.len(), 3)
check("pipeline run_all val", results.get(0), "12")
var err_pipeline = pipeline.create()
    .pipe(func(x)
        if x < 0 assert(false, "negative") end
        return x * 2
    end)
    .on_error(func(err, val) return 0 end)
check("pipeline on_error", err_pipeline.run(-1), 0)

# ── rate_limit ─────────────────────────────────────────────────────────────────
section("rate_limit")
library add "src/stdlib/rate_limit.cotlib"
var rl = rate_limit.create(3, 100)
check("rate_limit allow 1", rl.allow(), true)
check("rate_limit allow 2", rl.allow(), true)
check("rate_limit allow 3", rl.allow(), true)
check("rate_limit deny", rl.allow(), false)
check("rate_limit tokens 0", floor(rl.available_tokens()), 0)

# ── router ─────────────────────────────────────────────────────────────────────
section("router")
library add "src/stdlib/router.cotlib"
var r = router.create()
r.get("/hello", func(req, params) return {"status": 200, "body": "hi"} end)
r.get("/users/:id", func(req, params) return {"status": 200, "body": params.get("id")} end)
r.post("/data", func(req, params) return {"status": 201, "body": "created"} end)
r.not_found(func(req, params) return {"status": 404, "body": "nope"} end)
var resp1 = r.handle({"method": "GET", "path": "/hello", "query": "", "headers": {}, "body": ""})
check("router GET /hello", resp1.get("body"), "hi")
var resp2 = r.handle({"method": "GET", "path": "/users/42", "query": "", "headers": {}, "body": ""})
check("router param :id", resp2.get("body"), "42")
var resp3 = r.handle({"method": "POST", "path": "/data", "query": "", "headers": {}, "body": ""})
check("router POST /data", resp3.get("status"), 201)
var resp4 = r.handle({"method": "GET", "path": "/missing", "query": "", "headers": {}, "body": ""})
check("router not_found", resp4.get("status"), 404)

# ── middleware ─────────────────────────────────────────────────────────────────
section("middleware")
library add "src/stdlib/middleware.cotlib"
var base_handler = func(req) return {"status": 200, "body": "ok"} end
var cors_handler = middleware.cors(base_handler, "*")
var req_obj = {"method": "GET", "path": "/", "query": "", "headers": {}, "body": ""}
var cors_resp = cors_handler(req_obj)
check("middleware cors status", cors_resp.get("status"), 200)
check("middleware cors header", cors_resp.get("headers").has_key("Access-Control-Allow-Origin"), true)
var options_req = {"method": "OPTIONS", "path": "/", "query": "", "headers": {}, "body": ""}
var preflight = cors_handler(options_req)
check("middleware cors preflight", preflight.get("status"), 204)
var auth_handler = middleware.auth_bearer(base_handler, "secret123")
var authed_req = {"method": "GET", "path": "/", "query": "", "headers": {"authorization": "Bearer secret123"}, "body": ""}
var unauthed_req = {"method": "GET", "path": "/", "query": "", "headers": {"authorization": "Bearer wrong"}, "body": ""}
check("middleware auth ok", auth_handler(authed_req).get("status"), 200)
check("middleware auth fail", auth_handler(unauthed_req).get("status"), 401)

# ── json_schema ────────────────────────────────────────────────────────────────
section("json_schema")
library add "src/stdlib/json_schema.cotlib"
var schema = {"type": "map", "required": ["name", "age"], "properties": {"age": {"type": "number", "min": 0, "max": 150}}}
check("json_schema valid", json_schema.is_valid({"name": "Alice", "age": 30}, schema), true)
check("json_schema missing field", json_schema.validate({"name": "Alice"}, schema).len(), 1)
check("json_schema wrong type", json_schema.validate({"name": "Alice", "age": "30"}, schema).len() > 0, true)
check("json_schema min", json_schema.validate({"name": "Alice", "age": -1}, schema).len() > 0, true)
check("json_schema max", json_schema.validate({"name": "Alice", "age": 200}, schema).len() > 0, true)
check("json_schema string type", json_schema.is_valid("hello", {"type": "string"}), true)
check("json_schema number type", json_schema.is_valid(42, {"type": "number"}), true)

# ── sort edge cases ────────────────────────────────────────────────────────────
check("sort empty", sort.merge_sort([]).len(), 0)
check("sort single", sort.merge_sort([42]), [42])
check("sort already sorted", sort.merge_sort([1,2,3]), [1,2,3])

