# test — Unit testing framework

var _tests   = []
var _passed  = 0
var _failed  = 0
var _current = "default"

# Set the current test suite name.
func suite(name)
    _current = name
end

# Register and immediately run a test.
func it(description, fn)
    var full_name = _current + ": " + description
    try
        fn()
        _passed = _passed + 1
        print "  ✓ " + full_name
    catch err
        _failed = _failed + 1
        print "  ✗ " + full_name + " — " + err
    end
end

# Assertion helpers
func expect_eq(actual, expected)
    if actual != expected
        assert(false, "Expected " + to_string(expected) + " but got " + to_string(actual))
    end
end

func expect_neq(actual, unexpected)
    if actual == unexpected
        assert(false, "Expected value to not equal " + to_string(unexpected))
    end
end

func expect_true(val)
    if not val
        assert(false, "Expected true but got " + to_string(val))
    end
end

func expect_false(val)
    if val
        assert(false, "Expected false but got " + to_string(val))
    end
end

func expect_nil(val)
    if val != nil
        assert(false, "Expected nil but got " + to_string(val))
    end
end

func expect_not_nil(val)
    if val == nil
        assert(false, "Expected non-nil value")
    end
end

func expect_contains(lst, item)
    if is_list(lst)
        if not lst.contains(item)
            assert(false, "Expected list to contain " + to_string(item))
        end
    elif is_string(lst)
        if not lst.contains(item)
            assert(false, "Expected string to contain '" + to_string(item) + "'")
        end
    end
end

func expect_throws(fn)
    var threw = false
    try
        fn()
    catch err
        threw = true
    end
    if not threw
        assert(false, "Expected function to throw an error")
    end
end

func expect_in_range(val, min_val, max_val)
    if val < min_val or val > max_val
        assert(false, to_string(val) + " is not in range [" + to_string(min_val) + ", " + to_string(max_val) + "]")
    end
end

# Print final summary.
func summary()
    var total = _passed + _failed
    print ""
    print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    print "Results: " + to_string(total) + " tests — " + to_string(_passed) + " passed, " + to_string(_failed) + " failed"
    if _failed > 0
        print "FAIL"
        exit(1)
    end
    print "PASS"
end

func reset()
    _passed  = 0
    _failed  = 0
    _current = "default"
end
