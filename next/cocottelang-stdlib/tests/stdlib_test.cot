section("color_utils")
library add "src/stdlib/color_utils.cotlib"
var rgb = color_utils.hex_to_rgb("#ff0000")
check("color_utils hex_to_rgb r", rgb.get("r"), 255)
check("color_utils hex_to_rgb g", rgb.get("g"), 0)
check("color_utils hex_to_rgb b", rgb.get("b"), 0)
check("color_utils rgb_to_hex", color_utils.rgb_to_hex({"r": 255, "g": 0, "b": 0}), "#ff0000")

# ── db ─────────────────────────────────────────────────────────────────────────
section("db")
library add "src/stdlib/db.cotlib"
var db_path = "/tmp/cocotte_db_test_" + to_string(floor(time_now())) + ".db"
var test_db = db.open(db_path)
test_db.create_table("items", ["id INTEGER PRIMARY KEY AUTOINCREMENT", "name TEXT", "value INTEGER"])
test_db.insert("items", {"name": "alpha", "value": 10})
test_db.insert("items", {"name": "beta",  "value": 20})
test_db.insert("items", {"name": "gamma", "value": 30})
check("db count", test_db.count("items", "1=1"), 3)
check("db find", test_db.find("items", "value > 15").len(), 2)
var one = test_db.find_one("items", "name='alpha'")
check("db find_one", one.get("value"), 10)
check("db exists", test_db.exists("items", "name='beta'"), true)
check("db not exists", test_db.exists("items", "name='delta'"), false)
test_db.update("items", {"value": 99}, "name='alpha'")
var updated = test_db.find_one("items", "name='alpha'")
check("db update", updated.get("value"), 99)
test_db.delete("items", "name='gamma'")
check("db delete", test_db.count("items", "1=1"), 2)
check("db tables", test_db.tables().contains("items"), true)
delete_file(db_path)

# ── test framework self-test ───────────────────────────────────────────────────
section("test framework")
library add "src/stdlib/test.cotlib"
var tf_passed = 0
var tf_failed = 0
test.suite("self-test")
test.it("basic equality", func() test.expect_eq(1 + 1, 2) end)
test.it("true assertion", func() test.expect_true(5 > 3) end)
test.it("throws detection", func() test.expect_throws(func() assert(false, "boom") end) end)
test.it("range check", func() test.expect_in_range(5, 1, 10) end)
check("test framework no crash", true, true)

# ── assert framework ───────────────────────────────────────────────────────────
section("assert framework")
library add "src/stdlib/assert.cotlib"
assert.eq(2 + 2, 4, nil)
assert.gt(5, 3, nil)
assert.lt(3, 5, nil)
assert.is_true(true, nil)
assert.is_false(false, nil)
assert.not_nil("hello", nil)
assert.contains([1,2,3], 2, nil)
assert.in_range(5, 1, 10, nil)
check("assert no crash", true, true)

# ── Final report ───────────────────────────────────────────────────────────────
print ""
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
print "Results: " + to_string(_passed + _failed) + " assertions"
print "  Passed: " + to_string(_passed)
print "  Failed: " + to_string(_failed)
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if _failed > 0
    print ""
    print "FAILURES:"
    for err in _errors
        print "  " + err
    end
    print ""
    exit(1)
end
print "ALL PASSED ✓"
