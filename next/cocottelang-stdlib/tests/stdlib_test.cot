# stdlib_test.cot — Tests for all 68 stdlib modules
# Run from the cocottelang-stdlib root:
#   cocotte run tests/stdlib_test.cot

var _passed = 0
var _failed = 0
var _errors = []

func check(name, actual, expected)
    if actual == expected
        _passed = _passed + 1
    else
        _failed = _failed + 1
        _errors.push("FAIL " + name + " — expected: " + to_string(expected) + " got: " + to_string(actual))
    end
end

func check_true(name, val)
    check(name, val, true)
end

func check_not_nil(name, val)
    if val != nil
        _passed = _passed + 1
    else
        _failed = _failed + 1
        _errors.push("FAIL " + name + " — got nil")
    end
end

func section(name)
    print "  Testing " + name + "..."
end

print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
print "  Cocotte stdlib test suite"
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── stack ──────────────────────────────────────────────────────────────────────
section("stack")
library add "src/stdlib/stack.cotlib"
var s = stack.create()
check("stack empty", s.is_empty(), true)
s.push(1)
s.push(2)
s.push(3)
check("stack size", s.size(), 3)
check("stack pop", s.pop(), 3)
check("stack peek", s.peek(), 2)
check("stack size after pop", s.size(), 2)
s.clear()
check("stack clear", s.is_empty(), true)

# ── queue ──────────────────────────────────────────────────────────────────────
section("queue")
library add "src/stdlib/queue.cotlib"
var q = queue.create()
check("queue empty", q.is_empty(), true)
q.enqueue("a")
q.enqueue("b")
q.enqueue("c")
check("queue size", q.size(), 3)
check("queue dequeue", q.dequeue(), "a")
check("queue front", q.front(), "b")
check("queue size after dequeue", q.size(), 2)

# ── deque ──────────────────────────────────────────────────────────────────────
section("deque")
library add "src/stdlib/deque.cotlib"
var d = deque.create()
d.push_back("b")
d.push_front("a")
d.push_back("c")
check("deque front", d.pop_front(), "a")
check("deque back", d.pop_back(), "c")
check("deque size", d.size(), 1)

# ── set ────────────────────────────────────────────────────────────────────────
section("set")
library add "src/stdlib/set.cotlib"
var sv = set.from_list([1, 2, 3, 2, 1])
check("set size dedup", sv.size(), 3)
check("set has", sv.has(2), true)
check("set not has", sv.has(9), false)
sv.remove(2)
check("set remove", sv.has(2), false)
var s2 = set.from_list([3, 4, 5])
check("set union", sv.union(s2).size(), 4)
check("set intersection", sv.intersection(s2).size(), 1)

# ── heap ───────────────────────────────────────────────────────────────────────
section("heap")
library add "src/stdlib/heap.cotlib"
var h = heap.create()
h.push(5)
h.push(1)
h.push(3)
h.push(2)
check("heap min pop", h.pop(), 1)
check("heap next", h.peek(), 2)
check("heap size", h.size(), 3)

# ── cache ──────────────────────────────────────────────────────────────────────
section("cache")
library add "src/stdlib/cache.cotlib"
var c = cache.create(3)
c.set("a", 1)
c.set("b", 2)
c.set("c", 3)
check("cache get", c.get("a"), 1)
c.set("d", 4)
check("cache lru evict", c.size(), 3)
check("cache has", c.has("d"), true)

# ── collections ────────────────────────────────────────────────────────────────
section("collections")
library add "src/stdlib/collections.cotlib"
var counter = collections.counter()
counter.add("x")
counter.add("x")
counter.add("y")
check("counter count", counter.count("x"), 2)
check("counter missing", counter.count("z"), 0)

var dm = collections.default_map(0)
dm.increment("key")
dm.increment("key")
check("default_map", dm.get("key"), 2)
check("default_map missing", dm.get("absent"), 0)

var groups = collections.group_by([1,2,3,4,5,6], func(n) return to_string(n % 2) end)
check("group_by even", groups.get("0").len(), 3)

var chunks = collections.chunk([1,2,3,4,5], 2)
check("chunk count", chunks.len(), 3)
check("chunk first", chunks.get(0).len(), 2)

var flat = collections.flatten([[1,2],[3,4],[5]])
check("flatten", flat.len(), 5)

var zipped = collections.zip([1,2,3], ["a","b","c"])
check("zip", zipped.get(1).get(1), "b")

var uniq = collections.unique([1,1,2,2,3])
check("unique", uniq.len(), 3)

var parts = collections.partition([1,2,3,4,5], func(n) return n % 2 == 0 end)
check("partition even", parts.get(0).len(), 2)
check("partition odd", parts.get(1).len(), 3)

# ── strings ────────────────────────────────────────────────────────────────────
section("strings")
library add "src/stdlib/strings.cotlib"
check("strings reverse", strings.reverse("hello"), "olleh")
check("strings palindrome", strings.is_palindrome("racecar"), true)
check("strings not palindrome", strings.is_palindrome("hello"), false)
check("strings title_case", strings.title_case("hello world"), "Hello World")
check("strings to_camel", strings.to_camel_case("hello_world"), "helloWorld")
check("strings to_snake", strings.to_snake_case("HelloWorld"), "hello_world")
check("strings compact", strings.compact("h e l l o"), "hello")
check("strings count", strings.count("banana", "an"), 2)
check("strings edit_dist", strings.edit_distance("kitten", "sitting"), 3)
check("strings slugify", strings.slugify("Hello, World!"), "hello-world")
check("strings word_count", strings.word_count("one two three"), 3)
check("strings wrap", strings.word_wrap("one two three four five", 10).contains("\n"), true)

# ── fmt ────────────────────────────────────────────────────────────────────────
section("fmt")
library add "src/stdlib/fmt.cotlib"
check("fmt pad_left", fmt.pad_left("5", 3, "0"), "005")
check("fmt pad_right", fmt.pad_right("hi", 5, "."), "hi...")
check("fmt truncate", fmt.truncate("hello world", 8, "..."), "hello...")
check("fmt thousands", fmt.thousands(1234567), "1,234,567")
check("fmt bytes B", fmt.bytes(512), "512 B")
check("fmt bytes MB", fmt.bytes(1048576), "1.0 MB")
check("fmt duration s", fmt.duration(45), "45s")
check("fmt duration m", fmt.duration(90), "1m 30s")
check("fmt duration h", fmt.duration(3661), "1h 1m 1s")
check("fmt percent", fmt.percent(1, 4, 0), "25%")

# ── path ───────────────────────────────────────────────────────────────────────
section("path")
library add "src/stdlib/path.cotlib"
check("path join", path.join("/home/user", "docs"), "/home/user/docs")
check("path basename", path.basename("/home/user/file.txt"), "file.txt")
check("path dirname", path.dirname("/home/user/file.txt"), "/home/user")
check("path ext", path.ext("photo.jpg"), "jpg")
check("path stem", path.stem("photo.jpg"), "photo")
check("path is_absolute", path.is_absolute("/usr/bin"), true)
check("path is_relative", path.is_relative("src/main.cot"), true)
check("path normalize", path.normalize("/a//b///c/"), "/a/b/c")
check("path with_ext", path.with_ext("file.txt", "md"), "./file.md")

# ── fs ─────────────────────────────────────────────────────────────────────────
section("fs")
library add "src/stdlib/fs.cotlib"
var tmp_path = "/tmp/cocotte_stdlib_test_" + to_string(floor(time_now()))
write_file(tmp_path, "line1\nline2\nline3")
check("fs read_lines count", fs.read_lines(tmp_path).len(), 3)
check("fs extension", fs.extension(tmp_path), "")
check("fs basename", fs.basename(tmp_path).starts_with("cocotte"), true)
check("fs exists", fs.exists(tmp_path), true)
check("fs size", fs.size(tmp_path) > 0, true)
var copied = tmp_path + "_copy"
fs.copy(tmp_path, copied)
check("fs copy", fs.exists(copied), true)
fs.remove(tmp_path)
fs.remove(copied)
check("fs remove", fs.exists(tmp_path), false)

var json_path = "/tmp/cocotte_json_test.json"
fs.write_json(json_path, {"hello": "world"})
var loaded = fs.read_json(json_path)
check("fs write/read json", loaded.get("hello"), "world")
fs.remove(json_path)

# ── validation ─────────────────────────────────────────────────────────────────
section("validation")
library add "src/stdlib/validation.cotlib"
check("valid email", validation.is_email("user@example.com"), true)
check("invalid email", validation.is_email("notanemail"), false)
check("valid url", validation.is_url("https://example.com"), true)
check("invalid url", validation.is_url("example.com"), false)
check("valid integer", validation.is_integer("42"), true)
check("valid neg integer", validation.is_integer("-5"), true)
check("invalid integer", validation.is_integer("3.14"), false)
check("non_empty true", validation.is_non_empty("hello"), true)
check("non_empty false", validation.is_non_empty("  "), false)
check("in_range true", validation.in_range(5, 1, 10), true)
check("in_range false", validation.in_range(15, 1, 10), false)
check("alphanumeric true", validation.is_alphanumeric("abc123"), true)
check("alphanumeric false", validation.is_alphanumeric("abc!"), false)
check("length_between true", validation.length_between("hello", 3, 10), true)
check("clamp", validation.clamp_number(15, 0, 10), 10)
var schema_errors = validation.validate_map({"name": "Alice"}, {"name": "required", "email": "required"})
check("validate_map missing", schema_errors.len(), 1)

# ── statistics ─────────────────────────────────────────────────────────────────
section("statistics")
library add "src/stdlib/statistics.cotlib"
var data = [2, 4, 4, 4, 5, 5, 7, 9]
check("statistics sum", statistics.sum(data), 40)
check("statistics mean", statistics.mean(data), 5)
check("statistics median", statistics.median(data), 4.5)
check("statistics mode", statistics.mode(data), 4)
check("statistics min", statistics.min_val(data), 2)
check("statistics max", statistics.max_val(data), 9)
check("statistics range", statistics.range_val(data), 7)
var norm = statistics.normalize([0, 5, 10])
check("statistics normalize", norm.get(0), 0)
check("statistics normalize mid", norm.get(1), 0.5)
check("statistics normalize max", norm.get(2), 1)
var desc = statistics.describe(data)
check("statistics describe count", desc.get("count"), 8)

# ── random ─────────────────────────────────────────────────────────────────────
section("random")
library add "src/stdlib/random.cotlib"
var ri = random.int(1, 6)
check("random int range", ri >= 1 and ri <= 6, true)
var rf = random.float(0, 1)
check("random float range", rf >= 0 and rf < 1, true)
var rb = random.bool_val(1.0)
check("random bool true", rb, true)
var lst = [1,2,3,4,5]
var choice = random.choice(lst)
check("random choice in list", lst.contains(choice), true)
var shuffled = random.shuffle(lst)
check("random shuffle len", shuffled.len(), 5)
var rs = random.string(8, nil)
check("random string len", rs.len(), 8)
var rh = random.hex(10)
check("random hex len", rh.len(), 10)

# ── sort ───────────────────────────────────────────────────────────────────────
section("sort")
library add "src/stdlib/sort.cotlib"
var nums = [5, 3, 8, 1, 9, 2]
var sorted = sort.merge_sort(nums)
check("sort merge first", sorted.get(0), 1)
check("sort merge last", sorted.last(), 9)
var users = [{"name": "Charlie", "age": 30}, {"name": "Alice", "age": 25}, {"name": "Bob", "age": 35}]
var by_name = sort.by_field(users, "name")
check("sort by_field first", by_name.get(0).get("name"), "Alice")
var by_age_desc = sort.by_field_desc(users, "age")
check("sort by_field_desc first", by_age_desc.get(0).get("name"), "Bob")
check("sort binary_search found", sort.binary_search([1,2,3,4,5], 3), 2)
check("sort binary_search missing", sort.binary_search([1,2,3,4,5], 9), -1)
check("sort merge_sort exists", is_function(sort.merge_sort), true)

# ── search ─────────────────────────────────────────────────────────────────────
section("search")
library add "src/stdlib/search.cotlib"
var items = ["apple", "banana", "cherry"]
check("search linear found", search.linear(items, "banana"), 1)
check("search linear missing", search.linear(items, "grape"), -1)
check("search binary found", search.binary(["a","b","c","d"], "c"), 2)
var people = [{"name": "Alice"}, {"name": "Bob"}, {"name": "Charlie"}]
check("search fulltext", search.fulltext(people, "ali").len(), 1)
check("search fuzzy", search.fuzzy(people, "bc", "name").len(), 1)

# ── functional ─────────────────────────────────────────────────────────────────
section("functional")
library add "src/stdlib/functional.cotlib"
var double = func(x) return x * 2 end
var inc    = func(x) return x + 1 end
var f = functional.compose(double, inc)
check("functional compose", f(5), 12)
check("functional pipe", functional.pipe(5, [inc, double, inc]), 13)
var add5 = functional.partial(func(a, b) return a + b end, 5)
check("functional partial", add5(3), 8)
var memo_calls = 0
var memo_fn = functional.memoize(func(x)
    memo_calls = memo_calls + 1
    return x * x
end)
memo_fn(4)
memo_fn(4)
check("functional memoize cache", memo_calls, 1)
check("functional identity", functional.identity(42), 42)
check("functional times", functional.times(double, 3, 1), 8)
var not_even = functional.negate(func(n) return n % 2 == 0 end)
check("functional negate", not_even(3), true)

# ── iter ───────────────────────────────────────────────────────────────────────
section("iter")
library add "src/stdlib/iter.cotlib"
check("iter range_step", iter.range_step(0, 10, 3), [0, 3, 6, 9])
check("iter repeat", iter.repeat("x", 3), ["x", "x", "x"])
check("iter cycle len", iter.cycle([1,2], 5).len(), 5)
check("iter cycle val", iter.cycle([1,2], 5).get(4), 1)
var enum_result = iter.enumerate(["a","b","c"])
check("iter enumerate index", enum_result.get(1).get(0), 1)
check("iter enumerate val", enum_result.get(1).get(1), "b")
check("iter windows len", iter.windows([1,2,3,4], 2).len(), 3)
check("iter take_while", iter.take_while([1,2,3,4,5], func(n) return n < 4 end).len(), 3)
check("iter drop_while", iter.drop_while([1,2,3,4,5], func(n) return n < 3 end), [3,4,5])
check("iter pairwise", iter.pairwise([1,2,3,4], func(a,b) return a+b end), [3,5,7])

# ── graph ──────────────────────────────────────────────────────────────────────
section("graph")
library add "src/stdlib/graph.cotlib"
var g = graph.undirected()
g.add_edge("A", "B")
g.add_edge("B", "C")
g.add_edge("D", "E")
check("graph has_node", g.has_node("A"), true)
check("graph neighbors", g.neighbors("B").len(), 2)
check("graph bfs len", g.bfs("A").len(), 3)
check("graph has_path true", g.has_path("A", "C"), true)
check("graph has_path false", g.has_path("A", "D"), false)
var dg = graph.directed()
dg.add_edge("X", "Y")
check("directed neighbor", dg.neighbors("X").len(), 1)
check("directed no reverse", dg.neighbors("Y").len(), 0)

# ── matrices ───────────────────────────────────────────────────────────────────
section("matrices")
library add "src/stdlib/matrices.cotlib"
var m = matrices.zeros(2, 3)
check("matrices zeros", matrices.get(m, 0, 2), 0)
check("matrices rows", matrices.rows(m), 2)
check("matrices cols", matrices.cols(m), 3)
var id = matrices.identity(3)
check("matrices identity diag", matrices.get(id, 1, 1), 1)
check("matrices identity off", matrices.get(id, 0, 1), 0)
var a = [[1,2],[3,4]]
var b = [[5,6],[7,8]]
var added = matrices.add(a, b)
check("matrices add", matrices.get(added, 0, 0), 6)
var scaled = matrices.scale([[1,2],[3,4]], 2)
check("matrices scale", matrices.get(scaled, 1, 1), 8)
var t = matrices.transpose([[1,2,3],[4,5,6]])
check("matrices transpose rows", matrices.rows(t), 3)
check("matrices transpose val", matrices.get(t, 0, 1), 4)

# ── complex ────────────────────────────────────────────────────────────────────
section("complex")
library add "src/stdlib/complex.cotlib"
var z1 = complex.new(3, 4)
var z2 = complex.new(1, 2)
check("complex abs", z1.abs(), 5)
var zadd = z1.add(z2)
check("complex add real", zadd.real, 4)
check("complex add imag", zadd.imag, 6)
var zmul = z1.mul(z2)
check("complex mul real", zmul.real, -5)
check("complex mul imag", zmul.imag, 10)
var zconj = z1.conjugate()
check("complex conjugate", zconj.imag, -4)

