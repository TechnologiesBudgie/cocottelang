# ── passwords ──────────────────────────────────────────────────────────────────
section("passwords")
library add "src/stdlib/passwords.cotlib"
var pwd = passwords.generate(16, true)
check("passwords len", pwd.len(), 16)
check("passwords strength weak", passwords.strength("abc") <= 2, true)
check("passwords strength strong", passwords.strength("Abc123!@#xyz789") >= 3, true)
check("passwords strength_label", passwords.strength_label("abc"), "Very Weak")

# ── dotenv ─────────────────────────────────────────────────────────────────────
section("dotenv")
library add "src/stdlib/dotenv.cotlib"
var env_path = "/tmp/cocotte_test.env"
write_file(env_path, "PORT=9192\nDEBUG=true\nNAME=\"My App\"\n# comment\n")
var env_data = dotenv.load(env_path)
check("dotenv port", env_data.get("PORT"), "9192")
