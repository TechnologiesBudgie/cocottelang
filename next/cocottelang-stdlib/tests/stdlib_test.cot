# ── url ────────────────────────────────────────────────────────────────────────
section("url")
library add "src/stdlib/url.cotlib"
var parsed = url.parse("https://api.example.com:8080/users?page=2#top")
check("url scheme", parsed.get("scheme"), "https")
check("url host", parsed.get("host"), "api.example.com")
check("url port", parsed.get("port"), "8080")
check("url path", parsed.get("path"), "/users")
check("url query", parsed.get("query"), "page=2")
check("url fragment", parsed.get("fragment"), "top")
var qp = url.parse_query("a=1&b=hello+world&c=true")
check("url parse_query a", qp.get("a"), "1")
check("url parse_query b", qp.get("b"), "hello world")
var bq = url.build_query({"x": "1", "y": "2"})
check("url build_query contains", bq.contains("x=1"), true)
check("url join", url.join("https://example.com/api", "users"), "https://example.com/api/users")

