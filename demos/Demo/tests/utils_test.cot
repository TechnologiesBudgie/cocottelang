# tests/utils_test.cot — Tests for utils.cotlib
# Run with: cocotte test

library add "utils.cotlib"

print "Running utils library tests..."

# ── is_prime ──────────────────────────────────────────────────────────────────
assert_eq(utils.is_prime(0), false)
assert_eq(utils.is_prime(1), false)
assert_eq(utils.is_prime(2), true)
assert_eq(utils.is_prime(3), true)
assert_eq(utils.is_prime(4), false)
assert_eq(utils.is_prime(97), true)
assert_eq(utils.is_prime(100), false)

# ── primes_up_to ──────────────────────────────────────────────────────────────
var p10 = utils.primes_up_to(10)
assert_eq(p10.len(), 4)
assert_eq(p10.join(","), "2,3,5,7")

var p20 = utils.primes_up_to(20)
assert_eq(p20.len(), 8)

# ── gcd / lcm ─────────────────────────────────────────────────────────────────
assert_eq(utils.gcd(48, 18), 6)
assert_eq(utils.gcd(100, 75), 25)
assert_eq(utils.gcd(17, 5), 1)
assert_eq(utils.lcm(4, 6), 12)
assert_eq(utils.lcm(3, 5), 15)

# ── digit_sum ─────────────────────────────────────────────────────────────────
assert_eq(utils.digit_sum(123), 6)
assert_eq(utils.digit_sum(999), 27)
assert_eq(utils.digit_sum(0), 0)

# ── caesar cipher ────────────────────────────────────────────────────────────
assert_eq(utils.caesar("hello", 3), "khoor")
assert_eq(utils.caesar("khoor", -3), "hello")
assert_eq(utils.caesar("xyz", 3), "abc")
assert_eq(utils.caesar("Hello World", 13), "Uryyb Jbeyq")

# ── reverse_string ────────────────────────────────────────────────────────────
assert_eq(utils.reverse_string("hello"), "olleh")
assert_eq(utils.reverse_string("a"), "a")
assert_eq(utils.reverse_string(""), "")
assert_eq(utils.reverse_string("racecar"), "racecar")

# ── is_palindrome ─────────────────────────────────────────────────────────────
assert_eq(utils.is_palindrome("racecar"), true)
assert_eq(utils.is_palindrome("hello"), false)
assert_eq(utils.is_palindrome("A"), true)

# ── count_vowels ─────────────────────────────────────────────────────────────
assert_eq(utils.count_vowels("hello"), 2)
assert_eq(utils.count_vowels("AEIOU"), 5)
assert_eq(utils.count_vowels("bcdfg"), 0)

# ── word_count ────────────────────────────────────────────────────────────────
assert_eq(utils.word_count("hello world"), 2)
assert_eq(utils.word_count("  spaces   everywhere  "), 2)
assert_eq(utils.word_count("one"), 1)

# ── title_case ────────────────────────────────────────────────────────────────
assert_eq(utils.title_case("hello world"), "Hello World")
assert_eq(utils.title_case("cocotte is great"), "Cocotte Is Great")

# ── flatten ───────────────────────────────────────────────────────────────────
var nested = [[1, 2], [3, 4], [5]]
var flat = utils.flatten(nested)
assert_eq(flat.len(), 5)
assert_eq(flat.join(","), "1,2,3,4,5")

# ── unique ────────────────────────────────────────────────────────────────────
assert_eq(utils.unique([1,2,2,3,3,3]).len(), 3)
assert_eq(utils.unique(["a","b","a","c"]).len(), 3)

# ── zip ───────────────────────────────────────────────────────────────────────
var zipped = utils.zip([1,2,3], ["a","b","c"])
assert_eq(zipped.len(), 3)
assert_eq(zipped.get(0).get(0), 1)
assert_eq(zipped.get(0).get(1), "a")
assert_eq(zipped.get(2).get(1), "c")

# ── sum_list / average / median ───────────────────────────────────────────────
assert_eq(utils.sum_list([1,2,3,4,5]), 15)
assert_eq(utils.average([2,4,6]), 4)
assert_eq(utils.median([1,3,2]), 2)
assert_eq(utils.median([1,2,3,4]), 2.5)

# ── pipe ──────────────────────────────────────────────────────────────────────
var result = utils.pipe("  Hello World!  ", [
    func(s) return s.trim() end,
    func(s) return s.lower() end,
    func(s) return s.replace(" ", "_") end,
    func(s) return s.replace("!", "") end,
])
assert_eq(result, "hello_world")

print "All utils tests passed!"
