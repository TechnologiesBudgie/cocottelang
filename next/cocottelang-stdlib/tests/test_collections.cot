func section(name)
    print "  Testing " + name + "..."
end

section("collections")
library add "src/stdlib/collections.cotlib"
print "lib added"
var counter = collections.counter()
print "counter created"
counter.add("x")
counter.add("x")
counter.add("y")
print "added items"
assert(counter.count("x") == 2, "counter count x")
assert(counter.count("z") == 0, "counter count z")
print "counter tests done"

var dm = collections.default_map(0)
dm.increment("key")
dm.increment("key")
assert(dm.get("key") == 2, "default_map key")
assert(dm.get("absent") == 0, "default_map absent")

var groups = collections.group_by([1,2,3,4,5,6], func(n) return to_string(n % 2) end)
assert(groups.get("0").len() == 3, "group_by even")

var chunks = collections.chunk([1,2,3,4,5], 2)
assert(chunks.len() == 3, "chunk count")
assert(chunks.get(0).len() == 2, "chunk first")

var flat = collections.flatten([[1,2],[3,4],[5]])
assert(flat.len() == 5, "flatten")

var zipped = collections.zip([1,2,3], ["a","b","c"])
assert(zipped.get(1).get(1) == "b", "zip")

var uniq = collections.unique([1,1,2,2,3])
assert(uniq.len() == 3, "unique")

var parts = collections.partition([1,2,3,4,5], func(n) return n % 2 == 0 end)
assert(parts.get(0).len() == 2, "partition even")
assert(parts.get(1).len() == 3, "partition odd")

print "Collections test PASSED"

func section(name)
    print "  Testing " + name + "..."
end
