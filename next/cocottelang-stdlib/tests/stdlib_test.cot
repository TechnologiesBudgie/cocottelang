# ── colors ─────────────────────────────────────────────────────────────────────
section("colors")
library add "src/stdlib/colors.cotlib"
check("colors red", colors.red("x").contains("x"), true)
check("colors green contains reset", colors.green("hi").contains("\x1b[0m"), true)
check("colors strip", colors.strip(colors.bold("text")), "text")
check("colors success", colors.success("ok").contains("✓"), true)

# ── terminal ───────────────────────────────────────────────────────────────────
section("terminal")
library add "src/stdlib/terminal.cotlib"
var w = terminal.width()
check("terminal width > 0", w > 0, true)
var hv = terminal.height()
check("terminal height > 0", hv > 0, true)

# ── text ───────────────────────────────────────────────────────────────────────
section("text")
library add "src/stdlib/text.cotlib"
check("text line_count", text.line_count("a\nb\nc"), 3)
check("text words", text.words("hello world 123").len(), 3)
var freq = text.frequency("the cat sat on the mat")
check("text frequency the", freq.get("the"), 2)
check("text indent", text.indent("hello", 4), "    hello")
check("text grep", text.grep("foo bar\nhello\nfoo baz", "foo").len(), 2)
check("text summarize", text.summarize("First. Second. Third.", 1), "First.")

# ── markdown ───────────────────────────────────────────────────────────────────
section("markdown")
library add "src/stdlib/markdown.cotlib"
check("markdown h1", markdown.h1("Title"), "# Title\n")
check("markdown bold", markdown.bold("text"), "**text**")
check("markdown link", markdown.link("click", "http://x.com"), "[click](http://x.com)")
check("markdown ul item", markdown.ul(["a","b"]).contains("- a"), true)
check("markdown code_block", markdown.code_block("x=1","python").contains("```python"), true)
check("markdown table", markdown.table(["A","B"],[[1,2],[3,4]]).contains("---"), true)

# ── html ───────────────────────────────────────────────────────────────────────
section("html")
library add "src/stdlib/html.cotlib"
check("html h1", html.h1("Hello"), "<h1>Hello</h1>")
check("html p", html.p("text"), "<p>text</p>")
check("html a", html.a("click","http://x.com",nil), "<a href=\"http://x.com\">click</a>")
check("html escape", html.escape("<script>"), "&lt;script&gt;")
check("html ul", html.ul(["a","b"]).contains("<li>a</li>"), true)
check("html page", html.page("T","<p>hi</p>",nil).starts_with("<!DOCTYPE html>"), true)

# ── time ───────────────────────────────────────────────────────────────────────
section("time")
library add "src/stdlib/time.cotlib"
var ts = time.now()
check("time now > 0", ts > 0, true)
var sw2 = time.Stopwatch()
sleep(0.1)
check("time stopwatch elapsed", sw2.elapsed_secs() > 0, true)
var measured = time.measure(func() sleep(0.05) end)
check("time measure > 0", measured > 0, true)

# ── dates ──────────────────────────────────────────────────────────────────────
section("dates")
library add "src/stdlib/dates.cotlib"
check("dates is_leap 2000", dates.is_leap(2000), true)
check("dates is_leap 1900", dates.is_leap(1900), false)
check("dates is_leap 2024", dates.is_leap(2024), true)
check("dates days_in_month jan", dates.days_in_month(1, 2024), 31)
check("dates days_in_month feb leap", dates.days_in_month(2, 2024), 29)
check("dates days_in_month feb non-leap", dates.days_in_month(2, 2023), 28)
check("dates month_name", dates.month_name(1), "January")
check("dates day_name", dates.day_name(0), "Sunday")
var d = dates.parse_iso("2024-06-15")
check("dates parse year", d.get("year"), 2024)
check("dates parse month", d.get("month"), 6)
check("dates format_iso", dates.format_iso(d), "2024-06-15")
var tomorrow = dates.add_days(d, 1)
check("dates add_days", tomorrow.get("day"), 16)
var prev = dates.add_days(d, -1)
check("dates sub_days", prev.get("day"), 14)
var month_cross = dates.add_days({"year": 2024, "month": 1, "day": 31}, 1)
check("dates add_days month overflow", month_cross.get("month"), 2)

# ── env ────────────────────────────────────────────────────────────────────────
section("env")
library add "src/stdlib/env.cotlib"
check("env get with default", env.get("TOTALLY_UNSET_VAR_XYZ", "fallback"), "fallback")
check("env get_number default", env.get_number("TOTALLY_UNSET_VAR_XYZ", 42), 42)
check("env get_bool default", env.get_bool("TOTALLY_UNSET_VAR_XYZ", false), false)
check("env is_set false", env.is_set("TOTALLY_UNSET_VAR_XYZ"), false)
check("env is_set PATH", env.is_set("PATH"), true)

# ── systeminfo ─────────────────────────────────────────────────────────────────
