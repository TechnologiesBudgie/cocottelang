check("dotenv quoted", env_data.get("NAME"), "My App")
check("dotenv get with default", dotenv.get(env_path, "MISSING", "fallback"), "fallback")
delete_file(env_path)

# ── ini ────────────────────────────────────────────────────────────────────────
section("ini")
library add "src/stdlib/ini.cotlib"
var ini_text = "[database]\nhost = localhost\nport = 5432\n\n[app]\nname = myapp\ndebug = false\n"
var ini_data = ini.parse(ini_text)
check("ini section", ini.get(ini_data, "database", "host", nil), "localhost")
check("ini port", ini.get(ini_data, "database", "port", nil), "5432")
check("ini default", ini.get(ini_data, "database", "missing", "default"), "default")
var ini_str = ini.stringify(ini_data)
check("ini stringify", ini_str.contains("[database]"), true)

# ── csv ────────────────────────────────────────────────────────────────────────
section("csv")
library add "src/stdlib/csv.cotlib"
var csv_text = "name,age,city\nAlice,30,Paris\nBob,25,London\nCharlie,35,Tokyo\n"
var rows = csv.parse_with_header(csv_text, ",")
check("csv row count", rows.len(), 3)
check("csv first name", rows.get(0).get("name"), "Alice")
check("csv last city", rows.get(2).get("city"), "Tokyo")
var out = csv.stringify(rows, ",")
check("csv stringify header", out.starts_with("name,age,city") or out.starts_with("age,") or out.starts_with("city,"), true)

